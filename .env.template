APP_NAME=Listing Autopilot
APP_VERSION=0.1.0
APP_ENV=local
OUTPUT_DIR=outputs
MAX_UPLOAD_MB=10
DEFAULT_CUSTOMER_ID=demo-customer
DEFAULT_USER_ID=demo-user
ALLOWED_ORIGINS=*
LOG_LEVEL=INFO
UVICORN_ACCESS_LOG_LEVEL=WARNING
SQLALCHEMY_LOG_LEVEL=WARNING
IMAGE_PROVIDER_TIMEOUT_SECONDS=120

# Postgres persistence. Leave empty to run the core pipeline without DB writes.
DATABASE_URL=postgresql+psycopg2://listingautopilot:listingautopilot@localhost:5432/listingautopilot

# Optional live LLM providers. Demo provider works without keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=png
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_ASPECT_RATIO=1:1
GEMINI_IMAGE_SIZE=2K
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
